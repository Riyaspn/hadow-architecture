---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const services = await getCollection('services');
---

<Layout title="Services - HADOW Architecture">
  <section class="page-header">
    <h1 class="page-title">Our Capabilities</h1>
    <p class="page-subtitle">From master planning to bespoke product design, we shape holistic environments.</p>
  </section>

  <section class="services-section">
    {services.map((service, index) => (
      <div class="service-item">
        <div class="service-number">0{index + 1}.</div>
        <div class="service-text">
          <h2>{service.data.title}</h2>
          <div set:html={service.body}></div>
        </div>
      </div>
    ))}
  </section>
</Layout>
