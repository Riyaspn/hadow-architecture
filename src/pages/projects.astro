---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');
---

<Layout title="Projects - HADOW. Architecture">
  <section class="page-header">
    <h1 class="page-title">Selected Works</h1>
    <p class="page-subtitle">A showcase of our most recent architectural and interior projects.</p>
  </section>

  <section class="projects-grid-section">
    <div class="projects-grid">
      {projects.map(project => (
        <a href="#" class="project-card">
          <div class="project-image-wrapper">
            {project.data.image ? (
              <img src={project.data.image} alt={project.data.title} class="project-image" />
            ) : (
              <div class="project-image placeholder-img"></div>
            )}
          </div>
          <div class="project-info">
            <h3 class="project-title">{project.data.title}</h3>
            <p class="project-category">{project.data.category}</p>
          </div>
        </a>
      ))}
    </div>
  </section>
</Layout>
