---
import Layout from '../layouts/Layout.astro';
import { getEntry, getCollection } from 'astro:content';

const homePage = await getEntry('pages', 'home');
const teamMembers = await getCollection('team');
---

<Layout title="HADOW Architecture">
  <!-- Hero Parallax Section -->
  <section class="hero-section">
    <div class="hero-content" data-speed="0.5">
      <h1 set:html={homePage.data.heroTitle}></h1>
      <p>{homePage.data.heroSubtitle}</p>
    </div>
    <div class="hero-bg bg-layer-1" data-speed="0.2"></div>
    <div class="hero-bg bg-layer-2" data-speed="0.8"></div>
  </section>

  <!-- Scroll-Linked Image Sequence Section -->
  <section class="canvas-section">
    <div id="loading-indicator">Waiting for frames...</div>
    <canvas id="hero-lightpass"></canvas>
  </section>

  <!-- Vision / Quote Sticky Scroll Section -->
  <section class="vision-section">
    <div class="vision-container">
      <div class="vision-image-col">
        <div class="sticky-image-wrapper">
           {homePage.data.architectImage ? (
              <div class="sticky-image-placeholder" style={`background-image: linear-gradient(to top, rgba(0,0,0,0.8) 0%, transparent 50%), url('${homePage.data.architectImage}'); background-size: cover; background-position: center;`}>
                <span class="architect-name">{homePage.data.architectName}</span>
              </div>
           ) : (
              <div class="sticky-image-placeholder">
                <span class="architect-name">{homePage.data.architectName}</span>
              </div>
           )}
        </div>
      </div>
      <div class="vision-text-col">
        <div class="vision-text-block active">
          <h2>{homePage.data.visionTitle}</h2>
        </div>
        {homePage.data.visionText.map((item: any) => (
          <div class="vision-text-block">
            <p>{item.paragraph}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- The Team Section -->
  <section class="team-section">
    <h2>The Team</h2>
    <p class="team-subtitle">Meet the minds behind the momentum.</p>
    
    <div class="team-grid">
      {teamMembers.map(member => (
        <div class="team-member">
          {member.data.image ? (
            <img src={member.data.image} alt={member.data.name} class="member-image placeholder-img" style="object-fit: cover;" />
          ) : (
            <div class="member-image placeholder-img"></div>
          )}
          <h4>{member.data.name}</h4>
          <p>{member.data.role}</p>
        </div>
      ))}
    </div>
  </section>
</Layout>
